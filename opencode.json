{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "openrouter/arcee-ai/trinity-mini:free",
  "default_agent": "normalize",
  "provider": {
    "openrouter": {
      "models": {
        "arcee-ai/trinity-mini:free": {}
      },
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}",
        "baseURL": "https://openrouter.ai/api/v1"
      }
    }
  },
  "experimental": {
    "openTelemetry": true
  },
  "plugin": ["opencode-plugin-langfuse"],
  "agent": {
    "normalize": {
      "description": "Normalizes raw email requests into structured JSON. Reads email.md and extracted PDF text, then extracts organization details, classification, funding info, and context.",
      "mode": "primary",
      "model": "openrouter/arcee-ai/trinity-mini:free",
      "prompt": "{file:./prompts/opencode-normalize.md}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": false
      }
    }
  }
}
